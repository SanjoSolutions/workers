  "dependencies": {
    "commander": "^14.0.3",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
