{
  "name": "work",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "work": "./bin/work.mjs",
    "add-todo": "./bin/add-todo.mjs",
    "init-todo-repo": "./bin/init-todo-repo.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "work": "node ./build/work.js",
    "init-todo-repo": "node ./build/init-todo-repo.js",
    "add-todo": "node ./build/add-todo.js",
    "claim-todo": "tsx src/claim-todo.ts",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
