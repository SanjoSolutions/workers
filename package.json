{
  "name": "@sanjo/workers",
  "version": "0.1.1",
  "description": "A human-first process that supports spontaneity.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "assistant": "build/bin/assistant.js",
    "worker": "build/bin/worker.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x build/bin/assistant.js build/bin/worker.js",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "vitest run --exclude 'src/tests/e2e/**'",
    "test:e2e": "docker build -t workers-e2e . && docker run --rm -v \"$(pwd):/app\" -v /app/node_modules workers-e2e",
    "test:smoke": "scripts/smoke-test-coordinator.sh"
  },
  "files": [
    "build/",
    "src/scripts/",
    "agents/",
    "ASSISTANT_SYSTEM.md",
    "WORKER_SYSTEM.md"
  ],
  "dependencies": {
    "@inquirer/input": "^5.0.10",
    "@inquirer/select": "^5.1.2",
    "commander": "^14.0.3",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SanjoSolutions/workers.git"
  },
  "homepage": "https://github.com/SanjoSolutions/workers",
  "keywords": [
    "ai",
    "agents",
    "coding",
    "automation",
    "workers",
    "todo"
  ],
  "engines": {
    "node": ">=20"
  }
}
